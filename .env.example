# Application configuration
APP_NAME=exchange-ops-automation-service
ENVIRONMENT=development
DEBUG=true

# Database connection used by SQLAlchemy
DATABASE_URL=sqlite:///./exchange_ops.db

# Redis broker used for Celery background tasks
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Enable or disable the internal scheduler
ENABLE_SCHEDULER=true

# Interval (seconds) used for reconciliation job when scheduler is enabled
RECONCILIATION_INTERVAL_SECONDS=60
